      "id": "0c575bac-3df6-4f22-a73e-a8b22f768717",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst company = (body.company || '').trim();\nconst market = (body.market || '').trim();\n\n// Boş sorğuları rədd et\nif (!company || !market) {\n  throw new Error('Company and market are required');\n}\n\n// Çox uzun inputları kəs (prompt injection qoruması)\nreturn [{\n  json: {\n    ...body,\n    company: company.slice(0, 100),\n    market: market.slice(0, 80),\n    context: (body.context || '').slice(0, 500),\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
