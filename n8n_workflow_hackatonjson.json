    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output \n          || $input.first().json.text \n          || $input.first().json.message \n          || '';\n\nlet parsed;\ntry {\n  // Markdown-dan təmizləyirik\n  const clean = raw\n    .replace(/^```json\\s*/i, '')\n    .replace(/^```\\s*/i, '')\n    .replace(/```\\s*$/i, '')\n    .trim();\n    \n  parsed = JSON.parse(clean);\n} catch(e) {\n  // JSON parse olmadıqda fallback yaradırıq\n  const sentMatch = raw.match(/[Ss]entiment\\s*[Ss]core[:\\s]*([+-]?\\d+)/);\n  const sentRaw = sentMatch ? parseInt(sentMatch[1]) : null;\n  \n  parsed = {\n    report: raw,\n    sentiment: sentRaw,\n    opportunities: [],\n    risks: [],\n    signals_count: 0\n  };\n}\n\n// Sentiment-i 0-100 arasına normalizasiya et\nif (parsed.sentiment !== null && parsed.sentiment !== undefined) {\n  let s = Number(parsed.sentiment);\n  \n  // Əgər -10 və +10 arasındadırsa (eski ölçek), 0-100-ə çevir\n  if (s >= -10 && s <= 10) {\n    s = Math.round((s + 10) * 5);\n  }\n  \n  // Hər halda 0-100 arasına məcburi sal\n  parsed.sentiment = Math.min(100, Math.max(0, Math.round(s)));\n} else {\n  // Sentiment heç tapılmadısa default 50 (neytral) ver\n  parsed.sentiment = 50;\n}\n\nreturn [{ json: parsed }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
